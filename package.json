{
  "name": "cobranca-saas-api",
  "version": "0.1.0",
  "private": true,
  "description": "API cobranca, portal e inbox (importada do desenvolvimento EmissaoNF).",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "migrate": "tsx scripts/migrate.ts",
    "check:prod-env": "tsx scripts/check-production-env.ts",
    "check:db": "tsx scripts/check-db.ts",
    "check:readiness": "npm run check:prod-env -- --strict && npm run check:db",
    "seed:dev": "tsx scripts/seed-dev-portal.ts",
    "backfill:charge-automacao-tenant": "tsx scripts/backfill-charge-automacao-tenant-id.ts",
    "db:psql": "tsx scripts/db-psql.ts",
    "db:query": "tsx scripts/db-query.ts",
    "db:portal-app-user": "tsx scripts/db-portal-app-user.ts",
    "job:webhook-inbox": "tsx scripts/process-webhook-pending.ts",
    "test": "vitest run --exclude **/*.integration.test.ts",
    "test:coverage": "vitest run --exclude **/*.integration.test.ts --coverage",
    "test:integration": "vitest run tests/cross-tenant.integration.test.ts tests/webhook-charge-status.integration.test.ts tests/inbox/webhook-inbox-idempotency.integration.test.ts tests/functional/api-battery.integration.test.ts tests/functional/production-mock-auth-gate.integration.test.ts tests/health/health-ready.integration.test.ts tests/portal-read/sprint-a-portal-login.integration.test.ts tests/tenant-provisioning/sprint-a-provision.integration.test.ts tests/portal-read/portal-clientes-post.integration.test.ts tests/portal-read/sprint3-e2e-flow.integration.test.ts",
    "test:integration:sprint3": "vitest run tests/portal-read/sprint3-e2e-flow.integration.test.ts",
    "test:integration:sprint3:docker": "docker compose run --rm --no-deps migrate npx vitest run tests/portal-read/sprint3-e2e-flow.integration.test.ts",
    "test:integration:asaas": "vitest run tests/asaas-sandbox.e2e.integration.test.ts",
    "e2e:asaas:evidence": "tsx scripts/e2e-asaas-sandbox-evidence.ts",
    "test:stress:portal-clientes": "node scripts/run-stress-portal-clientes-vitest.cjs",
    "test:load:portal-clientes": "tsx scripts/load-test-portal-clientes.ts",
    "quality:gate": "npm run build && npm run test:coverage && npm run portal:test && npm run test:integration",
    "test:functional": "vitest run tests/functional/api-battery.integration.test.ts",
    "test:watch": "vitest",
    "portal:dev": "npm --prefix apps/portal-web run dev",
    "portal:build": "npm --prefix apps/portal-web run build",
    "portal:test": "npm --prefix apps/portal-web run test",
    "portal:preview": "npm --prefix apps/portal-web run preview",
    "dev:up": "powershell -ExecutionPolicy Bypass -File scripts/dev-up.ps1",
    "e2e:playwright": "playwright test -c e2e/playwright.config.cjs",
    "e2e:playwright:ui": "playwright test -c e2e/playwright.config.cjs --ui",
    "e2e:playwright:install": "playwright install chromium",
    "n8n:smoke:outbound": "node scripts/n8n-smoke-outbound.mjs",
    "gateway:smoke:inter": "tsx scripts/gateway-smoke-inter-sandbox.ts",
    "inter:oauth:check": "node scripts/inter-oauth-token.mjs",
    "gateway:smoke:cora": "tsx scripts/gateway-smoke-cora-sandbox.ts",
    "gateway:smoke:c6": "tsx scripts/gateway-smoke-c6-sandbox.ts",
    "postman:inter:setup-local": "node scripts/setup-postman-inter-local.mjs",
    "postman:inter:smoke": "node scripts/run-postman-inter-homolog.mjs --smoke",
    "postman:inter:homolog": "node scripts/run-postman-inter-homolog.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.10",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "newman": "^6.2.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
