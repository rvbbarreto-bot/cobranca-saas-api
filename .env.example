# Copie para .env e preencha os valores reais (nunca commite o .env).
# Guia: SETUP_POSTGRES_E_ENV.md | Producao: docs/PRODUCAO_ENDURECIMENTO_PASSO_A_PASSO.md
#
# Gerar secrets (exemplos):
#   JWT_SECRET:              openssl rand -base64 64
#   WEBHOOK_INBOX_SECRET:    openssl rand -hex 32
#   ENCRYPTION_KEY (Fase 1): openssl rand -hex 32

# ── Docker Compose (obrigatorio para postgres + migrate + api) ────────────────
# Deve ser IGUAL a POSTGRES_PASSWORD do container ja inicializado (nao inventar).
DB_PASSWORD=dev_only

# ── Obrigatorias (API em qualquer ambiente) ───────────────────────────────────
NODE_ENV=development
PORT=3333
# Host local: use docker compose run ou publique porta do postgres.
# Dentro do Compose a API usa host postgres (override no docker-compose.yml).
# Porta 5434 = docker compose (POSTGRES_HOST_PORT). Ajuste se usar Postgres local em 5432.
DATABASE_URL=postgres://app:dev_only@localhost:5434/cobranca_saas
JWT_SECRET=TROCAR_openssl_rand_base64_64_minimo_32_caracteres
WEBHOOK_INBOX_SECRET=TROCAR_openssl_rand_hex_32
CORS_ORIGIN=http://localhost:5173

# ── Pool e health ─────────────────────────────────────────────────────────────
PG_POOL_MAX=20
HEALTH_READY_DB_TIMEOUT_MS=3000
CHECK_DB_TIMEOUT_MS=8000

# ── Comportamento (dev vs producao) ───────────────────────────────────────────
# Rotas mock (/v1/auth/token/mock, etc.): desligadas em NODE_ENV=production por padrao.
ENABLE_MOCK_AUTH=false
# Log JSON de acesso HTTP (fora de test, ligado por padrao).
ENABLE_HTTP_ACCESS_LOG=true
# Apenas dev local sem TLS no Postgres — NUNCA em producao real.
ALLOW_INSECURE_DATABASE_URL=1
# Pular DB em testes manuais isolados (nao usar em CI).
# SKIP_DB=true

# ── Job npm run job:webhook-inbox ─────────────────────────────────────────────
# UUIDs de public.tenants separados por virgula; vazio = todos active.
# WEBHOOK_PROCESS_TENANT_IDS=
WEBHOOK_PROCESS_LIMIT=25

# ── Seed dev (npm run seed:dev) ───────────────────────────────────────────────
# Senha do usuario portal criado pelo seed (opcional; ha default em codigo).
# SEED_PORTAL_PASSWORD=PortalSeedDev!ChangeMe1

# ── Checagens de deploy (scripts/check-production-env.ts) ─────────────────────
# FORCE_PROD_ENV_CHECK=1

# ── Fase 0 — observabilidade (quando Sentry for integrado) ────────────────────
SENTRY_DSN=

# ── Fase 1 — gateway de pagamento (futuro) ────────────────────────────────────
REDIS_URL=redis://localhost:6379
ENCRYPTION_KEY=TROCAR_openssl_rand_hex_32_para_AES256GCM
# Sandbox: https://sandbox.asaas.com/ → Integrações → API Key ($aact_...)
ASAAS_API_KEY=TROCAR_sua_asaas_api_key
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
# E2E real: RUN_ASAAS_E2E=1 npm run test:integration:asaas
# Relatorio: npm run e2e:asaas:evidence

# ── Fase 2 — notificacoes (futuro) ────────────────────────────────────────────
RESEND_API_KEY=TROCAR_resend_api_key
ZAPI_INSTANCE=TROCAR_zapi_instance_id
ZAPI_TOKEN=TROCAR_zapi_token

# ── PORTAL DO CLIENTE ──────────────────────────────────────
PORTAL_CLIENT_URL=http://localhost:5173

# ── Sprint 4.6 — Webhooks outbound para n8n (opcional) ─────────────────────────
# N8N_PLATFORM_WEBHOOK_URL=https://seu-n8n/webhook/cobranca-saas-events
# N8N_PLATFORM_WEBHOOK_SECRET=

# ── Testes de carga / stress (opcional, CI ou local) ──────────────────────────
# RUN_PORTAL_CLIENTES_STRESS=1
# STRESS_CONCURRENCY=20
# STRESS_BATCHES=3
# LOAD_TOTAL=80
# LOAD_CONCURRENCY=25
